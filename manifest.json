{
  "manifest_version": 3,
  "name": "Edge Enhancer",
  "version": "1.0.0",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "scripting",
    "storage",
    "activeTab"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ]
}
